        "columns": { "mappingMode": "defineBelow", "value": { "Review_Sent": "Yes" } },
        "where": { "values": [{ "lookupColumn": "Confirmation_Code", "lookupValue": "={{ $json.confirmation_code }}" }] },
        "options": {}
