    {
      "parameters": {
        "fromEmail": "REPLACE_WITH_SENDER_EMAIL",
        "toEmail": "={{ $json.email }}",
        "subject": "=Time for your 6-month check-up, {{ $json.name }}! 🦷",
        "emailType": "html",
        "message": "=<html><body style=\"font-family: sans-serif; max-width: 600px; margin: auto; padding: 20px; background: #f8fafc;\">\n<div style=\"background: white; padding: 32px; border-radius: 12px; border-top: 4px solid #10b981;\">\n  <h2 style=\"color: #0f172a;\">It's time for your check-up! 🦷</h2>\n  <p>Hi {{ $json.name }},</p>\n  <p>It's been 6 months since your last visit with us. Regular check-ups are the best way to keep your smile healthy and catch any issues early.</p>\n  <div style=\"background: #f0fdf4; padding: 16px; border-radius: 8px; margin: 20px 0;\">\n    <p style=\"margin: 0; color: #15803d;\"><strong>✅ Last visit:</strong> {{ $json.visit_date }}<br><strong>🦷 Treatment:</strong> {{ $json.treatment }}</p>\n  </div>\n  <p style=\"text-align: center; margin: 28px 0;\">\n    <a href=\"REPLACE_WITH_BOOKING_URL\" style=\"background: #10b981; color: white; padding: 14px 32px; border-radius: 8px; text-decoration: none; font-weight: bold; font-size: 16px;\">📅 Book My Check-Up</a>\n  </p>\n  <p style=\"color: #64748b;\">Or call us at <strong>REPLACE_WITH_CLINIC_PHONE</strong> — we'd love to see you!</p>\n  <p style=\"color: #94a3b8; font-size: 12px;\">— REPLACE_WITH_CLINIC_NAME</p>\n</div>\n</body></html>",
        "options": {}
      },
      "id": "me12-0007-0007-0007-000000000007",
