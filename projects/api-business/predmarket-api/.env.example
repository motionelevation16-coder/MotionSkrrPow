# MarketPulse API — Environment Variables
# Copy this to .env and fill in your values

# OpenAI API key (required for AI endpoints: /markets/score, /sentiment/analyze, /alert/draft, /markets/{slug}/summary)
OPENAI_API_KEY=sk-...

# Your MarketPulse API key (used for auth on all endpoints)
# In production, use a secrets manager or database for multi-user key management
MARKETPULSE_API_KEY=your-secret-api-key-here

# Optional: override cache TTL in seconds (default: 300)
# CACHE_TTL_SECONDS=300

# Port (auto-set by Railway/Render/Heroku — don't set manually)
# PORT=8000
